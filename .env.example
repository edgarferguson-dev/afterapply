# Google Apps Script web app URL (Deploy → Web app → copy URL)
# Leave unset to use built-in demo data only.
# VITE_AFTERAPPLY_APPS_SCRIPT_URL=https://script.google.com/macros/s/AKfycb.../exec

# Production asset base path (Vite). Default build uses /afterapply/ for GitHub Pages project sites.
# For a host at the domain root (e.g. Vercel), set in .env.production:
# VITE_BASE=/
